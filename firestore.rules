rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function supportEmail() {
      return request.auth.token.email == "g.jesus140606@gmail.com";
    }

    function userDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isSupport() {
      return signedIn() && (supportEmail() || userDoc().role == "suporte");
    }

    function isAssistanceAdmin() {
      return signedIn() && userDoc().role == "assistencia_admin";
    }

    function isStoreAdmin() {
      return signedIn() && userDoc().role == "loja_admin";
    }

    function storeDoc(lojaId) {
      return get(/databases/$(database)/documents/lojas/$(lojaId)).data;
    }

    function hasStore(lojaId) {
      return signedIn() && (
        isSupport() ||
        lojaId in userDoc().lojaIds ||
        (
          isAssistanceAdmin() &&
          userDoc().assistenciaId == storeDoc(lojaId).assistenciaId
        )
      );
    }

    function managesTenant(assistenciaId) {
      return signedIn() && (
        isSupport() ||
        (
          userDoc().assistenciaId == assistenciaId &&
          userDoc().role == "assistencia_admin"
        )
      );
    }

    match /public_ordens/{orderId} {
      allow read: if true;
      allow create, update: if signedIn() && (isSupport() || hasStore(request.resource.data.lojaId));
      allow delete: if signedIn() && (isSupport() || hasStore(resource.data.lojaId));
    }

    match /usuarios/{userId} {
      allow read: if signedIn() && (
        isSupport() ||
        userId == request.auth.uid ||
        userDoc().assistenciaId == resource.data.assistenciaId
      );

      allow create: if signedIn() && (
        isSupport() ||
        (
          userId == request.auth.uid &&
          request.resource.data.email == "g.jesus140606@gmail.com" &&
          request.resource.data.role == "suporte"
        ) ||
        managesTenant(request.resource.data.assistenciaId)
      );

      allow update: if signedIn() && (
        isSupport() ||
        managesTenant(resource.data.assistenciaId)
      );

      allow delete: if isSupport();
    }

    match /assistencias/{assistenciaId} {
      allow read: if signedIn() && (
        isSupport() ||
        userDoc().assistenciaId == assistenciaId
      );
      allow create, update, delete: if isSupport();
    }

    match /avisos/{avisoId} {
      allow read: if signedIn() && (
        isSupport() ||
        resource.data.audience == "all" ||
        resource.data.assistenciaId == userDoc().assistenciaId
      );
      allow create, update, delete: if isSupport();
    }

    match /chamados/{chamadoId} {
      allow read: if signedIn() && (
        isSupport() ||
        resource.data.assistenciaId == userDoc().assistenciaId
      );
      allow create: if signedIn() && !isSupport() && request.resource.data.assistenciaId == userDoc().assistenciaId;
      allow update, delete: if isSupport();
    }

    match /asaas_logs/{logId} {
      allow read: if isSupport();
      allow create, update, delete: if false;
    }

    match /lojas/{lojaId} {
      allow read: if signedIn() && (
        isSupport() ||
        lojaId in userDoc().lojaIds ||
        (
          isAssistanceAdmin() &&
          userDoc().assistenciaId == resource.data.assistenciaId
        )
      );
      allow create, delete: if isSupport();
      allow update: if signedIn() && (
        isSupport() ||
        (
          isAssistanceAdmin() &&
          userDoc().assistenciaId == resource.data.assistenciaId
        ) ||
        (
          isStoreAdmin() &&
          lojaId in userDoc().lojaIds
        )
      );

      match /clientes/{clientId} {
        allow read, write: if hasStore(lojaId);
      }

      match /ordens/{orderId} {
        allow read: if hasStore(lojaId);
        allow create, update, delete: if hasStore(lojaId) && !(
          userDoc().role in ["financeiro", "leitura"]
        );
      }
    }
  }
}
